---
import { locales, localeLabels, getLocalizedUrl, type Locale } from "../../i18n/utils";

interface Props {
	currentLocale: Locale;
	class?: string;
}

const { currentLocale, class: className } = Astro.props;
---

<div class:list={["flex items-center gap-1 rounded-lg bg-gray-100 p-1", className]}>
	{
		locales.map((locale) => (
			<a
				href={getLocalizedUrl(locale)}
				class:list={[
					"px-2.5 py-1 text-sm font-medium rounded-md transition-colors",
					locale === currentLocale
						? "bg-white text-luna-700 shadow-sm"
						: "text-gray-500 hover:text-gray-700",
				]}
				aria-current={locale === currentLocale ? "page" : undefined}
			>
				{localeLabels[locale]}
			</a>
		))
	}
</div>
