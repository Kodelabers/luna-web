---
interface Props {
	variant?: "primary" | "secondary" | "ghost";
	size?: "sm" | "md" | "lg";
	href?: string;
	class?: string;
}

const { variant = "primary", size = "md", href, class: className } = Astro.props;

const baseClasses =
	"inline-flex items-center justify-center font-semibold rounded-lg transition-all duration-200 cursor-pointer";

const variants = {
	primary:
		"bg-gradient-to-r from-luna-500 to-luna-600 text-white hover:from-luna-600 hover:to-luna-700 shadow-lg shadow-luna-500/25 hover:shadow-luna-500/40",
	secondary:
		"border-2 border-luna-300 text-luna-700 hover:bg-luna-50 hover:border-luna-400",
	ghost: "text-luna-600 hover:text-luna-700 hover:bg-luna-50",
};

const sizes = {
	sm: "px-4 py-2 text-sm",
	md: "px-6 py-3 text-base",
	lg: "px-8 py-4 text-lg",
};

const classes = [baseClasses, variants[variant], sizes[size], className].join(" ");
const Tag = href ? "a" : "button";
---

<Tag href={href} class={classes}>
	<slot />
</Tag>
