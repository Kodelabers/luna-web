---
interface Props {
	title: string;
	subtitle?: string;
	align?: "left" | "center";
	light?: boolean;
}

const { title, subtitle, align = "center", light = false } = Astro.props;
---

<div class:list={[align === "center" && "text-center", "mb-12 lg:mb-16"]}>
	<h2
		class:list={[
			"text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl",
			light ? "text-white" : "text-gray-900",
		]}
	>
		{title}
	</h2>
	{
		subtitle && (
			<p
				class:list={[
					"mt-4 text-lg sm:text-xl max-w-3xl",
					align === "center" && "mx-auto",
					light ? "text-luna-200" : "text-gray-600",
				]}
			>
				{subtitle}
			</p>
		)
	}
</div>
