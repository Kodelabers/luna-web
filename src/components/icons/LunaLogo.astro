---
interface Props {
	size?: number;
	showWordmark?: boolean;
	class?: string;
}

const { size = 32, showWordmark = true, class: className } = Astro.props;
---

<div class:list={["flex items-center gap-2", className]}>
	<svg
		xmlns="http://www.w3.org/2000/svg"
		viewBox="0 0 32 32"
		width={size}
		height={size}
	>
		<defs>
			<linearGradient id="moonGradient" x1="0%" y1="0%" x2="100%" y2="100%">
				<stop offset="0%" style="stop-color:#A78BFA" />
				<stop offset="50%" style="stop-color:#8B5CF6" />
				<stop offset="100%" style="stop-color:#7C3AED" />
			</linearGradient>
			<radialGradient id="moonShadow" cx="30%" cy="30%" r="70%">
				<stop offset="0%" style="stop-color:#C4B5FD;stop-opacity:0.4" />
				<stop offset="100%" style="stop-color:#8B5CF6;stop-opacity:0" />
			</radialGradient>
		</defs>
		<circle cx="16" cy="16" r="14" fill="url(#moonGradient)" />
		<circle cx="16" cy="16" r="14" fill="url(#moonShadow)" />
		<circle cx="10" cy="12" r="2.5" fill="#7C3AED" opacity="0.3" />
		<circle cx="20" cy="10" r="1.8" fill="#7C3AED" opacity="0.25" />
		<circle cx="14" cy="20" r="3" fill="#7C3AED" opacity="0.2" />
		<circle cx="22" cy="18" r="1.5" fill="#7C3AED" opacity="0.25" />
		<circle cx="8" cy="19" r="1.2" fill="#7C3AED" opacity="0.2" />
	</svg>
	{
		showWordmark && (
			<span class="text-xl font-bold">Luna</span>
		)
	}
</div>
