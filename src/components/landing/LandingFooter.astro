---
import Container from "../ui/Container.astro";
import LunaLogo from "../icons/LunaLogo.astro";
import LanguageSwitcher from "../ui/LanguageSwitcher.astro";
import { useTranslations, type Locale } from "../../i18n/utils";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-400 pt-16 pb-8">
	<Container>
		<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4 pb-12 border-b border-gray-800">
			<!-- About column -->
			<div>
				<LunaLogo size={28} showWordmark={true} class="[&_span]:text-white" />
				<p class="mt-4 text-sm leading-relaxed">
					{t.footer.description}
				</p>
			</div>

			<!-- Product column -->
			<div>
				<h3 class="text-sm font-semibold text-white uppercase tracking-wider">
					{t.footer.product}
				</h3>
				<ul class="mt-4 space-y-2">
					{
						t.footer.productLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="text-sm hover:text-luna-400 transition-colors"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<!-- Company column -->
			<div>
				<h3 class="text-sm font-semibold text-white uppercase tracking-wider">
					{t.footer.company}
				</h3>
				<ul class="mt-4 space-y-2">
					{
						t.footer.companyLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="text-sm hover:text-luna-400 transition-colors"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<!-- Legal column -->
			<div>
				<h3 class="text-sm font-semibold text-white uppercase tracking-wider">
					{t.footer.legal}
				</h3>
				<ul class="mt-4 space-y-2">
					{
						t.footer.legalLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="text-sm hover:text-luna-400 transition-colors"
									{...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>

		<!-- Bottom bar -->
		<div class="mt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
			<p class="text-sm">
				&copy; {year} {t.footer.copyright}
			</p>
			<LanguageSwitcher
				currentLocale={locale}
				class="bg-gray-800 [&_a]:text-gray-400 [&_a[aria-current]]:bg-gray-700 [&_a[aria-current]]:text-white"
			/>
		</div>
	</Container>
</footer>
