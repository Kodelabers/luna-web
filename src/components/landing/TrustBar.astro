---
import Container from "../ui/Container.astro";
import { useTranslations, type Locale } from "../../i18n/utils";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const stats = [
	{ value: "1,000+", label: t.trustBar.employees },
	{ value: "5+", label: t.trustBar.organizations },
	{ value: "99.9%", label: t.trustBar.uptime },
	{ value: "98%", label: t.trustBar.satisfaction },
];
---

<section class="border-y border-gray-100 bg-gray-50/50 py-8">
	<Container>
		<div class="grid grid-cols-2 md:grid-cols-4 gap-8">
			{
				stats.map((stat) => (
					<div class="text-center">
						<div class="text-2xl font-bold text-luna-600 sm:text-3xl">{stat.value}</div>
						<div class="mt-1 text-sm text-gray-500">{stat.label}</div>
					</div>
				))
			}
		</div>
	</Container>
</section>
