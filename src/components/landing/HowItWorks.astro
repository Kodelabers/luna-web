---
import Container from "../ui/Container.astro";
import SectionHeading from "../ui/SectionHeading.astro";
import { useTranslations, type Locale } from "../../i18n/utils";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="how-it-works" class="py-16 sm:py-24 bg-gray-50/50">
	<Container>
		<SectionHeading title={t.howItWorks.title} subtitle={t.howItWorks.subtitle} />

		<div class="relative">
			<!-- Connecting line (desktop) -->
			<div
				class="hidden md:block absolute top-12 left-[calc(16.67%+24px)] right-[calc(16.67%+24px)] h-0.5 bg-luna-200"
			>
			</div>

			<div class="grid gap-8 md:grid-cols-3">
				{
					t.howItWorks.steps.map((step, index) => (
						<div class="relative text-center">
							<div class="mx-auto mb-6 flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-luna-500 to-luna-600 text-white text-lg font-bold shadow-lg shadow-luna-500/25">
								{index + 1}
							</div>
							<h3 class="text-lg font-semibold text-gray-900">{step.title}</h3>
							<p class="mt-2 text-gray-600 leading-relaxed">{step.description}</p>
						</div>
					))
				}
			</div>
		</div>
	</Container>
</section>
