---
import Container from "../ui/Container.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";
import FeatureIcons from "../icons/FeatureIcons.astro";
import { useTranslations, type Locale } from "../../i18n/utils";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="ai-scheduling" class="relative py-16 sm:py-24 overflow-hidden">
	<!-- Dark purple gradient background -->
	<div class="absolute inset-0 -z-10 bg-gradient-to-br from-luna-900 via-luna-800 to-luna-950">
		<div
			class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-luna-600/10 blur-3xl"
		>
		</div>
	</div>

	<Container>
		<div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
			<div>
				<Badge class="bg-luna-700/50 text-luna-200 mb-6">
					<FeatureIcons name="brain" size={14} class="mr-1.5" />
					{t.aiScheduling.badge}
				</Badge>

				<h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
					{t.aiScheduling.title}
				</h2>

				<p class="mt-4 text-lg text-luna-200">
					{t.aiScheduling.subtitle}
				</p>

				<p class="mt-6 text-luna-300 leading-relaxed">
					{t.aiScheduling.description}
				</p>

				<ul class="mt-8 space-y-3">
					{
						t.aiScheduling.features.map((feature) => (
							<li class="flex items-start gap-3 text-luna-200">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="20"
									height="20"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									class="text-luna-400 mt-0.5 flex-shrink-0"
								>
									<polyline points="20 6 9 17 4 12" />
								</svg>
								<span>{feature}</span>
							</li>
						))
					}
				</ul>
			</div>

			<!-- Waitlist form -->
			<div class="mt-12 lg:mt-0">
				<div class="rounded-2xl bg-white/5 backdrop-blur-sm border border-luna-700/30 p-8">
					<h3 class="text-xl font-semibold text-white mb-2">
						{t.aiScheduling.waitlistButton}
					</h3>
					<p class="text-luna-300 text-sm mb-6">
						{t.aiScheduling.subtitle}
					</p>

					<form class="flex flex-col sm:flex-row gap-3">
						<input
							type="email"
							placeholder={t.aiScheduling.waitlistPlaceholder}
							class="flex-1 rounded-lg bg-white/10 border border-luna-600/30 px-4 py-3 text-white placeholder-luna-400 focus:outline-none focus:ring-2 focus:ring-luna-400 focus:border-transparent"
						/>
						<Button variant="primary" size="md">
							{t.aiScheduling.waitlistButton}
						</Button>
					</form>

					<!-- Abstract scheduling visual -->
					<div class="mt-8 grid grid-cols-7 gap-1">
						{
							Array.from({ length: 28 }).map((_, i) => {
								const shiftColors = [
									"bg-luna-600/40",
									"bg-luna-500/30",
									"bg-luna-400/20",
									"bg-emerald-500/30",
									"bg-amber-500/30",
								];
								const color = shiftColors[i % shiftColors.length];
								return <div class:list={["h-4 rounded-sm", color]} />;
							})
						}
					</div>
					<div class="mt-2 flex items-center gap-4 text-xs text-luna-400">
						<span class="flex items-center gap-1">
							<span class="w-2 h-2 rounded-full bg-luna-500/50"></span>
							{locale === "hr" ? "Liječnici" : locale === "sl" ? "Zdravniki" : "Doctors"}
						</span>
						<span class="flex items-center gap-1">
							<span class="w-2 h-2 rounded-full bg-emerald-500/50"></span>
							{locale === "hr" ? "Sestre" : locale === "sl" ? "Medicinske sestre" : "Nurses"}
						</span>
						<span class="flex items-center gap-1">
							<span class="w-2 h-2 rounded-full bg-amber-500/50"></span>
							{
								locale === "hr"
									? "Specijalizanti"
									: locale === "sl"
										? "Specializanti"
										: "Residents"
							}
						</span>
					</div>
				</div>
			</div>
		</div>
	</Container>
</section>
