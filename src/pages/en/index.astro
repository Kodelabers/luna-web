---
import LandingPage from "../../layouts/LandingPage.astro";
import Hero from "../../components/landing/Hero.astro";
import TrustBar from "../../components/landing/TrustBar.astro";
import Features from "../../components/landing/Features.astro";
import AIScheduling from "../../components/landing/AIScheduling.astro";
import HowItWorks from "../../components/landing/HowItWorks.astro";
import CTA from "../../components/landing/CTA.astro";
import LandingFooter from "../../components/landing/LandingFooter.astro";
import { useTranslations } from "../../i18n/utils";

const locale = "en";
const t = useTranslations(locale);
---

<LandingPage title={t.meta.title} description={t.meta.description} locale={locale}>
	<Hero locale={locale} />
	<TrustBar locale={locale} />
	<Features locale={locale} />
	<AIScheduling locale={locale} />
	<HowItWorks locale={locale} />
	<CTA locale={locale} />
	<LandingFooter locale={locale} />
</LandingPage>
